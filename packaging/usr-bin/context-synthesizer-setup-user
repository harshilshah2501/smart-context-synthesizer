#!/bin/bash
# Enable per-user proxy — API key stays in ~/.claude/settings.json (Claude CLI BYOK).
set -euo pipefail

STATS_DIR="${HOME}/.local/share/context-synthesizer/stats"
mkdir -p "${STATS_DIR}"

if [[ -f "${HOME}/.config/context-synthesizer/env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "${HOME}/.config/context-synthesizer/env"
  set +a
fi

systemctl --user daemon-reload
systemctl --user enable --now context-synthesizer.service
systemctl --user status context-synthesizer.service --no-pager || true

echo ""
echo "Context Synthesizer running for ${USER}."
echo "  Telemetry: ${STATS_DIR}/telemetry.jsonl"
echo "  Claude CLI ~/.claude/settings.json:"
echo '    { "env": {'
echo '      "ANTHROPIC_BASE_URL": "http://127.0.0.1:8080",'
echo '      "ANTHROPIC_API_KEY": "sk-ant-...",'
echo '      "TELEMETRY_DEVELOPER_ID": "'"${USER}"'"'
echo '    } }'
echo ""
