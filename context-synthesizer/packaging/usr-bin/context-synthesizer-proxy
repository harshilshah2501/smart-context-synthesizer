#!/bin/bash
# Foreground proxy (debug) — production uses: sudo systemctl start context-synthesizer
set -euo pipefail
if [[ -f /etc/default/context-synthesizer ]]; then
  set -a
  # shellcheck disable=SC1091
  source /etc/default/context-synthesizer
  set +a
fi
exec /usr/lib/context-synthesizer/.venv/bin/python /usr/lib/context-synthesizer/proxy_tool.py "$@"
