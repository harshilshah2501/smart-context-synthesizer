# Copy to ~/.config/context-synthesizer/bundle-sync.env on WSL (destination machine).
# Used by fetch-toolkit-bundle.sh

# Build host (SSH) — e.g. your Linux dev server
BUILD_HOST="harshil@pro6000-server"
# Or IP: BUILD_HOST="harshil@192.168.1.50"

# Remote tarball (use -latest symlink after build-release-tarball.sh on server)
REMOTE_TARBALL="/home/harshil/Out-of-bound-chronicles/context-synthesizer/packaging/build/context-synthesizer-toolkit-latest.tar.gz"

# Local destination on WSL
LOCAL_DIR="/root/Harshil-PoCs"

# After rsync: extract tarball and replace toolkit folder (1=yes, 0=no)
EXTRACT=1

# Remove old extracted dirs matching context-synthesizer-toolkit-* before extract (1=yes)
PRUNE_OLD=1
