# Optional: copy to share.conf and edit for publish-to-sharepoint.sh
#   cp packaging/share.conf.example packaging/share.conf
#
# Team lead: bash packaging/publish-to-sharepoint.sh
# Developers: sync the published folder, then bash run-setup.sh firstname.lastname

# Windows path (Git Bash / publish script on Windows)
SHARE_DIR_WIN='C:\Users\you\OneDrive\YourTeam\Context-Synthesizer'

# WSL path to the same synced folder
SHARE_DIR_WSL='/mnt/c/Users/you/OneDrive/YourTeam/Context-Synthesizer'

# Stable folder name — developers always use this path
LATEST_NAME='context-synthesizer-toolkit-latest'
