[Unit]
Description=Context Synthesizer proxy (per-user, Claude CLI BYOK)
Documentation=file:/usr/share/doc/context-synthesizer/Usage.md
After=network-online.target

[Service]
Type=simple
Environment=TELEMETRY_LOG_PATH=%h/.local/share/context-synthesizer/stats/telemetry.jsonl
Environment=CLAUDE_MD_PATH=/etc/context-synthesizer/Claude.md
Environment=PROXY_HOST=127.0.0.1
Environment=PROXY_PORT=8080
Environment=PYTHONUNBUFFERED=1
WorkingDirectory=/usr/lib/context-synthesizer
ExecStart=/usr/lib/context-synthesizer/.venv/bin/python /usr/lib/context-synthesizer/proxy_tool.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
