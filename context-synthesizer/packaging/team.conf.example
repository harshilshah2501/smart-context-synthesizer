# Team lead: copy to team.conf and set your OneDrive path (after SharePoint Sync).
# Developers do not edit this file.

# Windows / WSL (typical):
SYNC_DIR="$HOME/OneDrive - Motadata/ContextSynthesizer/weekly"
# Ubuntu with abraunegg/onedrive (often):
# SYNC_DIR="$HOME/OneDrive/ContextSynthesizer/weekly"

# Primary USP: live context compaction (Claude Code → local proxy).
ENABLE_PROXY=1
# Optional: weekly SharePoint telemetry for team lead.
ENABLE_WEEKLY_CRON=1
EXTRA_SETUP_ARGS=()
# EXTRA_SETUP_ARGS=(--export-mode cursor --cursor-project my-project)
