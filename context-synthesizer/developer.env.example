# Copy to ~/.config/context-synthesizer/developer.env (setup_developer.sh does this for you)
TELEMETRY_DEVELOPER_ID=firstname.lastname
REPO_ROOT=/home/you/.local/share/context-synthesizer
EXPORT_MODE=d
# OneDrive sync folder (no rclone) — Motadata / SharePoint teams:
SYNC_DIR=/home/you/OneDrive - Motadata/ContextSynthesizer/weekly
# Or rclone (optional):
# RCLONE_REMOTE=gdrive:Shared/ContextSynthesizer/weekly
ENABLE_PROXY=0
CRON_HOUR=9
CRON_DOW=1
