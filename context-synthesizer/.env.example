# Copy to context-synthesizer/.env (setup_developer.sh creates this on WSL).
# Never commit .env — it may contain secrets.

# --- Proxy listen ---
PROXY_HOST=127.0.0.1
PROXY_PORT=8080

# WSL: setup sets PROXY_HOST=0.0.0.0 so Windows can reach the dashboard via WSL IP.
# WSL also auto-generates DASHBOARD_TOKEN when binding wide (see below).

# --- Auth (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...   # Fallback only; Claude Code forwards x-api-key by default.

# Required when PROXY_HOST=0.0.0.0 (auto-generated on WSL install):
# DASHBOARD_TOKEN=your-secret-token

# Restrict dashboard to loopback only (native Linux; breaks Windows→WSL browser):
# DASHBOARD_LOCALHOST_ONLY=1

# --- Compaction ---
# MAX_TURNS_THRESHOLD=10
# MAX_LAYER3_TURNS=10
# COMPACTION_TOKEN_THRESHOLD=100000

# --- Models ---
# ANTHROPIC_MODEL=claude-sonnet-4-6
# COMPACTION_MODEL=claude-haiku-4-5-20251001

# --- Telemetry ---
# TELEMETRY_DEVELOPER_ID=firstname.lastname
# TELEMETRY_LOG_PATH=context-synthesizer/stats/telemetry.jsonl
